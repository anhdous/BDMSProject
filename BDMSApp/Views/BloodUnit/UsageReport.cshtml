@model ApplicationCore.Models.UsageReportFilterModel

<div class="mb-3">
    <h3>Usage Report</h3>
</div>

<form method="post">
    <div class="row mb-3">
        <div class="col-md-3 mb-3">
            <label class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" />
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label">Component Type</label>
            <select class="form-control" asp-for="ComponentType">
                <option value="">-- All --</option>
                <option>RBC</option>
                <option>Plasma</option>
                <option>Platelets</option>
                <option>Cryoprecipitate</option>
            </select>
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label">Blood Type</label>
            <select class="form-control" asp-for="BloodType">
                <option value="">-- All --</option>
                <option>A</option>
                <option>B</option>
                <option>AB</option>
                <option>O</option>
            </select>
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label">Rh Factor</label>
            <select class="form-control" asp-for="RhFactor">
                <option value="">-- All --</option>
                <option>+</option>
                <option>-</option>
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end mb-3">
            <button class="btn btn-primary" type="submit">Search</button>
        </div>
    </div>

</form>

@if (Model.HasSearched)
{
    if (Model.Results != null && Model.Results.Any())
    {
        <h5>Results</h5>

        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Unit ID</th>
                    <th>Component Type</th>
                    <th>Blood Type</th>
                    <th>Volume</th>
                    <th>Request Date</th>
                    <th>Quantity</th>
                    <th>Request Hospital</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results)
                {
                    <tr>
                        <td>@item.UnitID</td>
                        <td>@item.ComponentType</td>
                        <td>@item.BloodType@item.RhFactor</td>
                        <td>@item.Volume cc</td>
                        <td>@item.RequestDate.ToShortDateString()</td>
                        <td>@item.Quantity</td>
                        <td>@item.RequestHospital</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning mt-3">
            No data found matching your search criteria.
        </div>
    }
}