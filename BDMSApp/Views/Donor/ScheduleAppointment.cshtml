@model ApplicationCore.Models.ScheduleAppointmentModel
@{
    ViewData["Title"] = "Schedule Appointment";
    var drives = ViewBag.Drives; // each has Id, Location, Title, StartDate, EndDate
}

<h3>@ViewData["Title"]</h3>
<form asp-action="@(Model.AppointmentID == 0 ? "ScheduleAppointment" : "EditAppointment")" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="AppointmentID" />
    <div class="mb-3">
        <label for="BDID" class="form-label">Location</label>
        <select asp-for="BDID" class="form-select" required>
            <option value="">-- Select a Location --</option>
            @foreach (var d in drives)
            {
                <option value="@d.BDID" selected="@(d.BDID == Model.BDID)" data-title="@d.Title" data-location="@d.Location"
                        data-startdate="@d.StartDate.ToString("yyyy-MM-dd")" data-enddate="@d.EndDate.ToString("yyyy-MM-dd")">
                    @d.Location
                </option>
            }
        </select>
        <span class="text-danger" data-valmsg-for="BDID"></span>
    </div>
    <input type="hidden" asp-for="Location" id="SelectedLocation" />

    <div class="mb-3">
        <label class="form-label">Event Name</label>
        <input id="titleDisplay" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Date" class="form-label"></label>
        <input asp-for="Date" type="date" class="form-control" required />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Time" class="form-label"></label>
        <input asp-for="Time" type="time" min="08:00" max="17:30" step="900" class="form-control" required />
        <span asp-validation-for="Time" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
   <script>
(function () {
    const select = document.getElementById('BDID');
    const titleDiv = document.getElementById('titleDisplay');
    const hiddenLocation = document.getElementById('SelectedLocation');
    const dateInput = document.getElementById('Date');
    const timeInput = document.getElementById('Time');

    function updateFromSelection() {
        const opt = select.options[select.selectedIndex];

        const title = opt?.getAttribute('data-title') || '';
        const location = opt?.getAttribute('data-location') || '';
        const startDate = opt?.getAttribute('data-startdate') || '';
        const endDate = opt?.getAttribute('data-enddate') || '';

        titleDiv.value = title;
        hiddenLocation.value = location;

        // reset first
        dateInput.value = '';

        // set min/max first
        dateInput.min = startDate || '';
        dateInput.max = endDate || '';

        // then set value
        if (startDate) {
            dateInput.value = startDate;
        }
    }
    select.addEventListener('change', updateFromSelection);
    updateFromSelection();
})();
</script>
}